# Copy this file to ".env" and fill in ONE provider's key. The .env file is gitignored.
#
# Choose which vision backend plans the tutorial steps. If you don't set
# AI_PROVIDER, it is auto-detected from whichever *_API_KEY below is present
# (groq > openrouter > gemini).
# AI_PROVIDER=gemini        # one of: groq | openrouter | gemini

# --- OpenRouter (recommended) ------------------------------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Default vision model is Qwen2.5-VL (best UI grounding). It is NOT free
# (~$0.80/M input tokens — a tutorial call costs a fraction of a cent), so your
# OpenRouter account needs a small credit balance. To stay 100% free, override
# with a free vision model:
# OPENROUTER_MODEL=qwen/qwen2.5-vl-72b-instruct          # default (paid, cheap)
# OPENROUTER_MODEL=nvidia/nemotron-nano-12b-v2-vl:free   # free alternative

# --- Groq (genuinely free tier, fast; uses a Llama-4 vision model) -----------
# Get a free key at https://console.groq.com/keys
# GROQ_API_KEY=your_groq_key_here
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct   # optional override

# --- Google Gemini (multimodal, strong coordinate accuracy) ------------------
# Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.5-flash        # default. NOTE: gemini-2.0-flash / 1.5-pro
#                                      # may have 0 free-tier quota; 2.5-flash works.

# --- Runtime flags -----------------------------------------------------------
# OVERLAY_INTERACTIVE=1  # no click-through (REQUIRED on Linux; leave unset on Windows)
